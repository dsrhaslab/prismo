; 22_write_heavy_seq_uring
[global]
filename=/dev/nvme0n1
size=66262417408
ioengine=io_uring
iodepth=128
sqthread_poll=1
sqthread_poll_cpu=0
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[22_write_heavy_seq_uring]
bs=4k
rw=rw
rwmixread=10
number_ios=16165652
buffer_compress_percentage=0
