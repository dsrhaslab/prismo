; 51_rw_zipf_spdk
[global]
filename=Nvme0n1
size=66262417408
ioengine=/home/gsd/spdk/build/fio/spdk_bdev
spdk_json_conf=/home/gsd/prismo/workloads/bdev/nvme_bdev.json
iodepth=128
thread=1
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000
norandommap=1

[51_rw_zipf_spdk]
bs=4k
rw=randrw
rwmixread=50
random_distribution=zipf:0.9
runtime=900
time_based
buffer_compress_percentage=0
