; 06_rw_zipf_posix
[global]
filename=/dev/nvme0n1
size=66262417408
ioengine=psync
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[06_rw_zipf_posix]
bs=4k
rw=randrw
rwmixread=50
random_distribution=zipf:0.9
runtime=900
time_based
buffer_compress_percentage=0
