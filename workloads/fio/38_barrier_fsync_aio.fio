; 38_barrier_fsync_aio
[global]
filename=/dev/nvme0n1
size=66262417408
ioengine=libaio
iodepth=128
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[38_barrier_fsync_aio]
bs=4k
rw=randrw
rwmixread=25
fsync=1024
runtime=900
time_based
buffer_compress_percentage=0
