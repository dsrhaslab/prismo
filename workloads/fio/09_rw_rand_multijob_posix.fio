; 09_rw_rand_multijob_posix
[global]
filename=/dev/nvme0n1
ioengine=psync
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000
buffer_compress_percentage=0

[job1]
offset=0
size=23622320128
bs=4k
rw=randrw
rwmixread=50
runtime=900
time_based

