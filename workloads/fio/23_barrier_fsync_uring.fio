; 23_barrier_fsync_uring
[global]
filename=/dev/nvme0n1
size=66262417408
ioengine=io_uring
iodepth=128
sqthread_poll=1
sqthread_poll_cpu=0
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[23_barrier_fsync_uring]
bs=4k
rw=randrw
rwmixread=25
fsync=1024
runtime=900
time_based
buffer_compress_percentage=0
