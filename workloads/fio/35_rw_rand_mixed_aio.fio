; 35_rw_rand_mixed_aio
[global]
filename=/dev/nvme0n1
size=66262417408
ioengine=libaio
iodepth=128
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[35_rw_rand_mixed_aio]
bs=4k
rw=randrw
rwmixread=50
runtime=900
time_based
buffer_compress_percentage=0
