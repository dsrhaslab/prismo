; 25_compress_zipf_uring
[global]
filename=/tank/testfile_campaign
size=66262417408
ioengine=io_uring
iodepth=128
sqthread_poll=1
sqthread_poll_cpu=0
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[25_compress_zipf_uring]
bs=4k
rw=randrw
rwmixread=33
random_distribution=zipf:0.9
number_ios=16165652
buffer_compress_percentage=30
refill_buffers
