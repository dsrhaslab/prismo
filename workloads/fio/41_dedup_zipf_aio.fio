; 41_dedup_zipf_aio
[global]
filename=/tank/testfile_campaign
size=66262417408
ioengine=libaio
iodepth=128
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[41_dedup_zipf_aio]
bs=4k
rw=randrw
rwmixread=33
random_distribution=zipf:0.9
number_ios=16165652
dedupe_percentage=50
buffer_compress_percentage=20
refill_buffers
