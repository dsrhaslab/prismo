; 44_trace_homes_aio
[global]
filename=/tank/testfile_campaign
size=66262417408
ioengine=libaio
iodepth=128
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[44_trace_homes_aio]
bs=4k
rw=randrw
rwmixread=50
number_ios=16165652
; NOTE: prismo replays homes-110108-112108.1.blkparse.prismo
; For exact trace replay: use replay_redirect with blktrace files
