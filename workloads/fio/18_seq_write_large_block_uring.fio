; 18_seq_write_large_block_uring
[global]
filename=/dev/nvme0n1
size=66262417408
ioengine=io_uring
iodepth=128
sqthread_poll=1
sqthread_poll_cpu=0
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[18_seq_write_large_block_uring]
bs=64k
rw=write
number_ios=1011084
buffer_compress_percentage=0
