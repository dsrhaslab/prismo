; 08_barrier_fsync_posix
[global]
filename=/dev/nvme0n1
size=66262417408
ioengine=psync
direct=1
write_bw_log=$jobname
write_lat_log=$jobname
write_iops_log=$jobname
log_avg_msec=1000

[08_barrier_fsync_posix]
bs=4k
rw=randrw
rwmixread=25
fsync=1024
time_based
runtime=900
buffer_compress_percentage=0
