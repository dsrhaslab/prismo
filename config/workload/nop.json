{
  "job": {
    "name": "job",
    "numjobs": 1,
    "iterations": 1e7,
    "filename": "testfile",
    "block_size": 4096,
    "limit": 65536,
    "metric": "none"
  },

  "operation": {
    "type": "constant",
    "operation": "nop",
    "barrier": []
  },

  "access": {
    "type": "sequential"
  },

  "generator": {
    "type": "constant"
  },

  "engine": {
    "type": "posix",
    "openflags": [
      "O_CREAT",
      "O_RDWR"
    ],
    "entries": 128,
    "params": {
      "cq_entries": 0,
      "sq_thread_cpu": 0,
      "sq_thread_idle": 0,
      "flags": [
        "IORING_SETUP_SQPOLL"
      ]
    },
    "bdev_name": "Malloc0",
    "reactor_mask": "0xF",
    "spdk_threads": 4,
    "json_config_file": "/home/digo/Desktop/prismo/config/spdk_bdev.json"
  },

  "logging": {
    "type": "spdlog",
    "name": "prismo",
    "queue_size": 8192,
    "thread_count": 1,
    "truncate": true,
    "to_stdout": true,
    "files": [
      "./log1.log",
      "./log2.log",
      "./log3.log"
    ]
  }
}
