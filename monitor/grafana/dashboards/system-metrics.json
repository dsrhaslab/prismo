        { "expr": "rate(node_disk_writes_completed_total{device!~\"loop.*|dm-.*\"}[1m])", "legendFormat": "write {{device}}", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
